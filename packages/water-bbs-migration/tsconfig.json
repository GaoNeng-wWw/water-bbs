{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    "declarationMap": false,
    "module": "commonjs",
    "target": "ES2020",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "experimentalDecorators": true,
    "paths": {
      "water-bbs-shared": ["./node_modules/water-bbs-shared/src"],
      "water-bbs-shared/*": ["./node_modules/water-bbs-shared/src/*"],
    }
  },
  "include": ["migrations/**/*.ts", "entities/index.ts", "entities/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}