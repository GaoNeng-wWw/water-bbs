{
  "moduleFileExtensions": [
    "js",
    "json",
    "ts"
  ],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "^@app/configure(|/.*)$": "<rootDir>/../libs/configure/src/$1",
    "^@app/shared(|/.*)$": "<rootDir>/../libs/shared/src/$1"
  }
}